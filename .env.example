# Copy to .env and fill in your Supabase credentials.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
# Set to true to use Supabase Auth + database instead of the local mock layer.
VITE_USE_SUPABASE=false

# Live market data — free key from https://finnhub.io/register
VITE_FINNHUB_API_KEY=your-finnhub-key
VITE_USE_LIVE_DATA=true
